# Obsidian ephemeral state (per-window layout, caches)
.obsidian/workspace
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache

# Obsidian plugin data — often holds API keys / private keys (e.g. Local REST API)
.obsidian/plugins/*/data.json

# Trash
.trash/

# macOS
.DS_Store

# Claude Code local/runtime state (skills + commands ARE tracked)
.claude/settings.local.json
.claude/*.lock

# Redundant archive — extracted dir phase3-explicit-solvent-md/ is tracked instead
phase3-explicit-solvent-md.zip

# Scratch / working / demo artifacts (kept on disk, not canonical vault content)
phase3-explicit-solvent-md/_archive/
phase3-explicit-solvent-md/_demo-work/
mdin-edit/
deliverables-mdin-edit-*/
